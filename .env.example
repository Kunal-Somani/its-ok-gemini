# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Application Environment
ENVIRONMENT=development

# GitHub Configuration
GITHUB_USERNAME=your_github_username
GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY_B64=your_base64_encoded_github_private_key

# LLM Backend Configuration
  # LLM Backend — Local Qwen2.5-Coder-7B-Instruct (no API key required)
  # Download model first: bash scripts/download_model.sh
  MODEL_PATH=models/qwen2.5-coder-7b-instruct-q4_k_m.gguf
  MODEL_N_CTX=32768
  MODEL_N_GPU_LAYERS=0
  MODEL_MAX_TOKENS=8192
  MODEL_N_THREADS=4

# Database Configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=archon
DB_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# API Configuration
API_PORT=8000

# Prometheus Configuration
PROMETHEUS_PORT=9090

# RAG Configuration
COHERE_API_KEY=
EMBEDDING_MODEL=embed-english-v3.0
RAG_VECTOR_DIMENSION=1024

# Security Configuration
API_KEY=G8Hj3kL9_zXqV-wA1yM_t2U7o8CqVnRk
JWT_SECRET=
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
