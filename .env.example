# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Application Environment
ENVIRONMENT=development

# GitHub Configuration
GITHUB_USERNAME=your_github_username
GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY_B64=your_base64_encoded_github_private_key

# LLM Backend Configuration (vLLM - Self-Hosted Inference)
LLM_BACKEND=vllm
VLLM_ENDPOINT=http://localhost:8001/v1
VLLM_MODEL=deepseek-coder-v2
VLLM_CONTEXT_WINDOW=128000
VLLM_TIMEOUT=300

# Legacy: Gemini API Configuration (deprecated, optional)
GEMINI_API_KEY=

# Database Configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=its_ok_gemini
DB_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# API Configuration
API_PORT=8000

# Prometheus Configuration
PROMETHEUS_PORT=9090

